# ------------------------------------------------------------------------------
# alden-bot environment configuration
# ------------------------------------------------------------------------------

# Optional comma-separated list of BotAdmin user IDs.
# BotAdmins have access to restricted commands like /reload, /plugins.
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Bot command prefix
# Default: /
BOT_PREFIX=/

# Default language for new users
DEFAULT_LANGUAGE=vi

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Dangerous commands are disabled by default.
ENABLE_EVAL_COMMAND=false
ENABLE_RELOAD_COMMAND=false

# Whether to reply "Unknown command" when a command is not found.
# Default is false to prevent noise in multi-bot environments.
REPLY_UNKNOWN_COMMAND=false

# Delay in milliseconds between outgoing messages (rate limiting).
# Default is 500ms. Set to 0 to disable spacing.
MESSAGE_QUEUE_DELAY=500
